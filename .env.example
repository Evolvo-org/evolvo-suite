# API
PORT=3000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3001
DATABASE_URL=postgresql://evolvo:evolvo@localhost:5432/evolvo?schema=public
LOG_LEVEL=log

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1

# Runtime
RUNTIME_ID=runtime-local
RUNTIME_DISPLAY_NAME=Evolvo Local Runtime
RUNTIME_CAPABILITIES=git,leases,heartbeats
API_BASE_URL=http://localhost:3000/api/v1
API_AUTH_TOKEN=
API_RETRY_MAX_ATTEMPTS=3
API_RETRY_BASE_DELAY_MS=500
REPOSITORIES_ROOT=./.runtime/repos
HEARTBEAT_INTERVAL_MS=30000
WORK_POLLING_ENABLED=false
WORK_POLL_INTERVAL_MS=15000
WORK_POLL_IDLE_BACKOFF_MS=5000
WORK_POLL_MAX_BACKOFF_MS=60000
LEASE_PROGRESS_INTERVAL_MS=30000
