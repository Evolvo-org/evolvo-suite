{
  "name": "@repo/api",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "pnpm build --watch",
    "build": "tsc -b -v",
    "lint": "biome lint --config-path ../biome-config/library.json ./src"
  },
  "files": ["./dist/**"],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./dto/create-link.dto": {
      "import": "./dist/dto/create-link.dto.js",
      "require": "./dist/dto/create-link.dto.js",
      "types": "./dist/dto/create-link.dto.d.ts"
    },
    "./dto/update-link.dto": {
      "import": "./dist/dto/update-link.dto.js",
      "require": "./dist/dto/update-link.dto.js",
      "types": "./dist/dto/update-link.dto.d.ts"
    },
    "./entities/link.entity": {
      "import": "./dist/entities/link.entity.js",
      "require": "./dist/entities/link.entity.js",
      "types": "./dist/entities/link.entity.d.ts"
    }
  },
  "dependencies": {
    "@nestjs/mapped-types": "*"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.10.7",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3"
  }
}
