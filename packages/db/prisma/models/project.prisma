
enum ProjectLifecycleStatus {
  DRAFT
  ACTIVE
  PAUSED
}

enum RepositorySetupStatus {
  PENDING
  IN_PROGRESS
  READY
  FAILED
}

enum ProjectRepositoryProvider {
  GITHUB
}

enum PlanningApprovalAuditAction {
  APPROVED
  RESET
}

model Project {
  id                  String                 @id @default(cuid())
  name                String
  slug                String                 @unique
  lifecycleStatus     ProjectLifecycleStatus @default(DRAFT)
  repositorySetupStatus RepositorySetupStatus @default(PENDING)
  repositorySetupMessage String?             @db.Text
  repositorySetupError String?               @db.Text
  repositorySetupUpdatedAt DateTime          @default(now())
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  repository          ProjectRepository?
  agentRouting        ProjectAgentRouting?
  productSpec         ProductSpec?
  developmentPlan     DevelopmentPlan?
  queueLimits         ProjectQueueLimits?
  managementCommands  ManagementCommand[]
  epics               Epic[]
  workItems           WorkItem[]
}

model ProjectAgentRouting {
  id              String   @id @default(cuid())
  projectId       String   @unique
  defaultProvider String
  defaultModel    String
  agentRoutesJson Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectRepository {
  id            String                    @id @default(cuid())
  projectId     String                    @unique
  provider      ProjectRepositoryProvider @default(GITHUB)
  owner         String
  name          String
  url           String
  defaultBranch String                    @default("main")
  baseBranch    String                    @default("main")
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  project       Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectQueueLimits {
  id                      String   @id @default(cuid())
  projectId               String   @unique
  maxPlanning             Int
  maxReadyForDev          Int
  maxInDev                Int
  maxReadyForReview       Int
  maxInReview             Int
  maxReadyForRelease      Int
  maxReviewRetries        Int
  maxMergeConflictRetries Int
  maxRuntimeRetries       Int
  maxAmbiguityRetries     Int
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  project                 Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model SystemQueueLimits {
  id                      String   @id
  maxPlanning             Int
  maxReadyForDev          Int
  maxInDev                Int
  maxReadyForReview       Int
  maxInReview             Int
  maxReadyForRelease      Int
  maxReviewRetries        Int
  maxMergeConflictRetries Int
  maxRuntimeRetries       Int
  maxAmbiguityRetries     Int
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model SystemAgentRouting {
  id              String   @id
  defaultProvider String
  defaultModel    String
  agentRoutesJson Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ProductSpec {
  id        String   @id @default(cuid())
  projectId String   @unique
  content   String   @db.Text
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model DevelopmentPlan {
  id                       String                       @id @default(cuid())
  projectId                String                       @unique
  title                    String
  activeVersionId          String?                      @unique
  planningApprovedVersionId String?                     @unique
  planningApprovedAt       DateTime?
  planningApprovedBy       String?
  planningApprovalSummary  String?                      @db.Text
  createdAt                DateTime                     @default(now())
  updatedAt                DateTime                     @updatedAt
  project                  Project                      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activeVersion            PlanVersion?                 @relation("ActivePlanVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)
  planningApprovedVersion  PlanVersion?                 @relation("ApprovedPlanVersion", fields: [planningApprovedVersionId], references: [id], onDelete: SetNull)
  versions                 PlanVersion[]                @relation("PlanVersions")
  epics                    Epic[]
  approvalAudit            DevelopmentPlanApprovalAudit[]
}

model PlanVersion {
  id                  String                        @id @default(cuid())
  developmentPlanId   String
  versionNumber       Int
  title               String
  content             String                        @db.Text
  summary             String?
  createdAt           DateTime                      @default(now())
  developmentPlan     DevelopmentPlan               @relation("PlanVersions", fields: [developmentPlanId], references: [id], onDelete: Cascade)
  activatedBy         DevelopmentPlan?              @relation("ActivePlanVersion")
  approvedByPlan      DevelopmentPlan?              @relation("ApprovedPlanVersion")
  approvalAuditEvents DevelopmentPlanApprovalAudit[]

  @@unique([developmentPlanId, versionNumber])
}

model DevelopmentPlanApprovalAudit {
  id                String                      @id @default(cuid())
  developmentPlanId String
  planVersionId     String
  action            PlanningApprovalAuditAction @default(APPROVED)
  actorName         String
  summary           String?                     @db.Text
  createdAt         DateTime                    @default(now())
  developmentPlan   DevelopmentPlan             @relation(fields: [developmentPlanId], references: [id], onDelete: Cascade)
  planVersion       PlanVersion                 @relation(fields: [planVersionId], references: [id], onDelete: Cascade)

  @@index([developmentPlanId, createdAt])
  @@index([planVersionId, createdAt])
}
