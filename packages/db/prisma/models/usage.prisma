model UsageEvent {
  id               String   @id @default(cuid())
  projectId        String
  workItemId       String?
  agentRunId       String?
  runtimeId        String?
  userId           String?
  agentType        String
  provider         String
  model            String
  inputTokens      Int      @default(0)
  outputTokens     Int      @default(0)
  totalTokens      Int      @default(0)
  estimatedCostUsd Decimal  @default(0) @db.Decimal(12, 6)
  occurredAt       DateTime @default(now())
  createdAt        DateTime @default(now())
  workItem         WorkItem? @relation(fields: [workItemId], references: [id], onDelete: SetNull)
  agentRun         AgentRun? @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  runtime          RuntimeInstance? @relation(fields: [runtimeId], references: [id], onDelete: SetNull)

  @@index([projectId, occurredAt])
  @@index([userId, occurredAt])
  @@index([provider, model, occurredAt])
  @@index([agentType, occurredAt])
  @@index([workItemId, occurredAt])
  @@index([agentRunId, occurredAt])
  @@index([runtimeId, occurredAt])
}
