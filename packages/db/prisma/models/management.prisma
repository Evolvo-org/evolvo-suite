enum ManagementCommandType {
  REPO_CLONE_OR_SYNC
}

enum ManagementCommandStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

model ManagementCommand {
  id            String                  @id @default(cuid())
  projectId     String
  commandType   ManagementCommandType
  status        ManagementCommandStatus @default(PENDING)
  requestedBy   String?
  runtimeId     String?
  argsJson      Json
  activeStage   String?
  statusSummary String?                 @db.Text
  resultJson    Json?
  errorMessage  String?                 @db.Text
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  startedAt     DateTime?
  completedAt   DateTime?
  project       Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runtime       RuntimeInstance?        @relation(fields: [runtimeId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([status, createdAt])
  @@index([runtimeId, createdAt])
}