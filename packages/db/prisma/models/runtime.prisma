enum RuntimeStatus {
  IDLE
  BUSY
  DEGRADED
}

enum RuntimeArtifactType {
  LOG
  PATCH
  TEST_REPORT
  BUILD_OUTPUT
  RELEASE_NOTE
  OTHER
}

model RuntimeInstance {
  id               String        @id
  displayName      String
  status           RuntimeStatus @default(IDLE)
  capabilities     String[]      @default([])
  activeJobSummary String?       @db.Text
  lastAction       String?       @db.Text
  lastError        String?       @db.Text
  lastSeenAt       DateTime      @default(now())
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  agentRuns        AgentRun[]
  artifacts        RuntimeArtifact[]
  releaseRuns      ReleaseRun[]
  reviewGateResults ReviewGateResult[]
  usageEvents      UsageEvent[]
  worktrees        Worktree[]
  managementCommands ManagementCommand[]
}

model RuntimeArtifact {
  id          String              @id @default(cuid())
  runtimeId   String
  leaseId     String
  artifactType RuntimeArtifactType
  fileName    String
  contentType String?
  sizeBytes   Int?
  storageKey  String              @unique
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  runtime     RuntimeInstance     @relation(fields: [runtimeId], references: [id], onDelete: Cascade)
  lease       WorkItemLease       @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([runtimeId, createdAt])
  @@index([leaseId, createdAt])
}
