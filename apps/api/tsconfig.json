{
  "extends": "@repo/typescript-config/nestjs.json",
  "compilerOptions": {
    "baseUrl": "./",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "./dist",
    "strictNullChecks": true,
    "paths": {
      "@repo/db": ["../../packages/db/src"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "jest.config.ts",
    "vitest.config.ts",
    "vitest.e2e.config.ts"
  ]
}
