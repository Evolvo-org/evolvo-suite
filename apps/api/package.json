{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "nest start",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/bootstrap/main",
    "test": "vitest run --config ./vitest.config.ts",
    "test:watch": "vitest --config ./vitest.config.ts",
    "test:debug": "node --inspect-brk ./node_modules/vitest/vitest.mjs run --config ./vitest.config.ts",
    "test:e2e": "vitest run --config ./vitest.e2e.config.ts",
    "lint": "biome lint --config-path ../../packages/biome-config/nest.json ./src ./test"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-express": "^11.1.16",
    "@repo/api": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "escape-html": "^1.0.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.16",
    "@repo/vitest-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.3",
    "@types/supertest": "^7.2.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.3",
    "vitest": "^2.1.8"
  }
}
