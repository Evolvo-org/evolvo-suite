{
  "name": "api",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @repo/db build",
    "dev": "nest start --watch",
    "prebuild": "pnpm --filter @repo/db build",
    "build": "nest build",
    "prestart": "pnpm --filter @repo/db build",
    "start": "nest start",
    "prestart:debug": "pnpm --filter @repo/db build",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "pretest": "pnpm --filter @repo/db build",
    "test": "vitest run --config ./vitest.config.ts",
    "test:watch": "vitest --config ./vitest.config.ts",
    "test:debug": "node --inspect-brk ./node_modules/vitest/vitest.mjs run --config ./vitest.config.ts",
    "pretest:e2e": "pnpm --filter @repo/db build",
    "test:e2e": "vitest run --config ./vitest.e2e.config.ts",
    "lint": "biome lint --config-path ../../packages/biome-config/nest.json ./src ./test"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/platform-socket.io": "^11.1.16",
    "@nestjs/websockets": "^11.1.16",
    "@prisma/adapter-pg": "^7.4.2",
    "@repo/db": "workspace:*",
    "@repo/shared": "workspace:*",
    "@repo/validation": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.16",
    "@repo/typescript-config": "workspace:*",
    "@repo/vitest-config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.3",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^2.1.8",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.3",
    "vitest": "^2.1.8"
  }
}
