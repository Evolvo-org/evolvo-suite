{
  "name": "web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node ./scripts/next-with-root-env.cjs dev --turbopack --port 3001",
    "build": "node ./scripts/next-with-root-env.cjs build",
    "start": "node ./scripts/next-with-root-env.cjs start",
    "cypress:open": "cypress open --e2e",
    "cypress:run": "cypress run --e2e",
    "test:e2e": "start-server-and-test dev http://localhost:3001 cypress:run",
    "test:e2e:open": "start-server-and-test dev http://localhost:3001 cypress:open",
    "test": "vitest run",
    "lint": "biome lint --config-path ../../packages/biome-config/next.json ./app",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@repo/api-client": "workspace:*",
    "@repo/shared": "workspace:*",
    "@repo/ui": "workspace:*",
    "@repo/validation": "workspace:*",
    "@tanstack/react-query": "^5.66.8",
    "next": "16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@repo/vitest-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "cypress": "^15.11.0",
    "dotenv": "^16.4.7",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.8",
    "start-server-and-test": "^2.1.5",
    "tailwindcss": "^4.2.1",
    "typescript": "5.9.3",
    "vitest": "^2.1.8"
  }
}
